# ─────────────────────────────────────────────────────────────────────────────
# Aria Voice Agent — Environment Variables
# Copy to .env and fill in your real values. Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# LiveKit (local dev defaults — change for production / LiveKit Cloud)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Deepgram — free tier: https://deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs — free tier: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # Bella voice (change freely)

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database (SQLite by default — change to PostgreSQL for production)
DATABASE_URL=sqlite:///restaurant.db
